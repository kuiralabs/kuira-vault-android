# Gradle
.gradle/
build/
out/
.kotlin/

# Android
*.apk
*.aab
*.dex
local.properties
.idea/
*.iml
captures/

# Signing material — release keystores and keystore.properties must
# never be committed. Move them outside the repo (e.g. ~/keystores/)
# and reference them via gradle.properties or env vars at build time.
*.keystore
*.jks
keystore.properties

# Compact / npm
node_modules/
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# Kuira test workspace caches (regenerated)
.gradle/configuration-cache/

# mn CLI dApp wallet cache (regenerated on every deploy/call)
midnight-level-db/

# Contract assets — generated by the io.github.kuiralabs.contract plugin
# from contract/src/managed/ at build time. Sourced, not stored.
app/src/main/assets/managed/
app/src/main/assets/runtime/
app/src/main/assets/keys/
# Wallet proving keys (#256) — downloaded from S3 + staged by provisionWalletKeys
# when bundleWalletKeys is on. ~33MB of generated bytes — sourced, not stored.
app/src/main/assets/wallet-keys/
